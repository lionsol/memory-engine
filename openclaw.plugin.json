{
  "id": "memory-engine",
  "name": "Memory Engine",
  "description": "Enhanced memory with confidence scoring, time-decay, and lifecycle management.",
  "contracts": {
    "tools": [
      "memory_engine",
      "memory_engine_search",
      "memory_engine_get"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "archiveThreshold": {
        "type": "number",
        "default": 0.15,
        "description": "Confidence threshold for automatic archival"
      },
      "conflictPenalty": {
        "type": "number",
        "default": 0.5,
        "description": "Penalty applied to conflicted memories"
      },
      "beta": {
        "type": "number",
        "default": 0.3,
        "description": "Consolidation rate factor"
      },
      "autoRecall": {
        "type": "object",
        "additionalProperties": false,
        "default": {
          "enabled": false,
          "topK": 3,
          "timeoutMs": 8000
        },
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable before_prompt_build auto recall injection"
          },
          "topK": {
            "type": "number",
            "default": 3,
            "description": "Number of memories to inject before each prompt"
          },
          "timeoutMs": {
            "type": "number",
            "default": 8000,
            "description": "Timeout for auto recall before_prompt_build hook in milliseconds"
          },
          "agentAllowlist": {
            "type": "array",
            "default": [
              "edi"
            ],
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Agent IDs allowed to pass the AutoRecall runtime gate; defaults remain edi-only and should be expanded only for controlled runtime verification"
          },
          "triggerAllowlist": {
            "type": "array",
            "default": [
              "user"
            ],
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Trusted hook triggers allowed to pass the AutoRecall runtime gate; defaults remain user-only"
          },
          "chatTypeAllowlist": {
            "type": "array",
            "default": [
              "interactive_user_chat"
            ],
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Chat types allowed to pass the AutoRecall runtime gate"
          },
          "messageRoleAllowlist": {
            "type": "array",
            "default": [
              "user"
            ],
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Message roles allowed to pass the AutoRecall runtime gate"
          },
          "cardFirstRuntime": {
            "type": "object",
            "additionalProperties": false,
            "default": {
              "enabled": false
            },
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": false,
                "description": "Enable experimental edi-only card-first auto recall prompt supplement"
              }
            }
          }
        }
      },
      "kgFailClosedMode": {
        "type": "string",
        "enum": [
          "legacy_fallback",
          "shadow_fail_closed",
          "fail_closed_canary",
          "full_fail_closed"
        ],
        "default": "legacy_fallback",
        "description": "KG legacy-fallback policy for all Hybrid Search production surfaces; keep legacy_fallback unless executing the controlled rollout runbook"
      },
      "kgFailClosedCanary": {
        "type": "object",
        "additionalProperties": false,
        "default": {
          "enabled": false,
          "agentIds": [],
          "sessionIds": []
        },
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "agentIds": {
            "type": "array",
            "default": [],
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "sessionIds": {
            "type": "array",
            "default": [],
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "recentFailClosedMode": {
        "type": "string",
        "enum": [
          "legacy_fallback",
          "shadow_fail_closed",
          "fail_closed_canary",
          "full_fail_closed"
        ],
        "default": "legacy_fallback",
        "description": "Recent legacy-fallback policy for all Hybrid Search production surfaces; keep legacy_fallback unless executing the controlled rollout runbook"
      },
      "recentFailClosedCanary": {
        "type": "object",
        "additionalProperties": false,
        "default": {
          "enabled": false,
          "agentIds": [],
          "sessionIds": []
        },
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "agentIds": {
            "type": "array",
            "default": [],
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "sessionIds": {
            "type": "array",
            "default": [],
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "productionEvidenceWindow": {
        "type": "object",
        "additionalProperties": false,
        "default": {
          "enabled": false
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "enabled": {
                  "const": true
                }
              },
              "required": [
                "enabled"
              ]
            },
            "then": {
              "required": [
                "epochId"
              ]
            }
          }
        ],
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "epochId": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "activation": {
    "onStartup": true
  }
}
