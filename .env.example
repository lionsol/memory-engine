# ============================================
# Memory Engine 环境变量示例
# 复制为 .env 并填入真实值。.env 已被 gitignore，不会入库。
# ============================================

# ----- SiliconFlow API -----
# 向量化（embedding）与 LLM 调用所需的 SiliconFlow API Key
# 获取地址：https://siliconflow.cn
# 解析优先级：本环境变量 > ~/.openclaw/openclaw.json > 插件 cfg
SILICONFLOW_API_KEY=

# ----- 时区（可选）-----
# 覆盖默认业务时区（默认 Asia/Shanghai）
# 仅当你的使用场景与默认时区不同时才需要设置
MEMORY_ENGINE_TIME_ZONE=Asia/Shanghai
