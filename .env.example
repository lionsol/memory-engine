# Memory Engine environment variables
# Copy this file to .env and fill values locally.
# .env is ignored by git.

# SiliconFlow API Key for embedding/vector retrieval.
# Resolution priority should be:
#   1. this environment variable
#   2. ~/.openclaw/openclaw.json
#   3. plugin config
SILICONFLOW_API_KEY=

# Business timezone. Default: Asia/Shanghai
MEMORY_ENGINE_TIME_ZONE=Asia/Shanghai
