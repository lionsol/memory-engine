<section class="toolbar">
  <h1>Safety Reports</h1>
  <button class="icon-button" data-refresh title="Refresh">↻</button>
</section>
<section class="grid metrics" data-report-latest-cards></section>
<section>
  <h2>Memory Card Preview</h2>
  <div class="panel report-detail" data-report-memory-card-preview-primary>
    <div class="muted">Turn gold-set replay cards will appear here when a replay report is available.</div>
  </div>
</section>
<section class="split">
  <section>
    <h2>Safety Status</h2>
    <div class="panel report-status" data-report-status></div>
  </section>
  <section>
    <h2>Latest Report</h2>
    <div class="panel report-detail" data-report-detail>
      <div class="muted">Select a report to preview.</div>
    </div>
    <h2>Long Input Decision Trace</h2>
    <div class="panel report-detail" data-report-decision-trace>
      <div class="muted">Available for supporting autoRecall reports.</div>
    </div>
    <h2>Memory Card Preview Details</h2>
    <div class="panel report-detail" data-report-memory-card-preview>
      <div class="muted">Available for turn gold-set replay reports. Read-only preview only; use explicit memory_engine_get outside this viewer for full content.</div>
    </div>
    <h2>Annotation QC Preview</h2>
    <div class="panel report-detail" data-report-annotation-qc-preview>
      <div class="muted">Available for browser-local annotation QC reports. Read-only preview only.</div>
    </div>
    <h2>Review Queue Label Preview</h2>
    <div class="panel report-detail" data-report-review-queue-label-preview>
      <div class="muted">Available for archived raw-log rescue review queue label reports. Read-only preview only.</div>
    </div>
  </section>
</section>
<section class="split wide-left">
  <section>
    <h2>Allowed Reports</h2>
    <div class="panel table-wrap"><table data-reports-table></table></div>
  </section>
  <section>
    <h2>Read-only Boundaries</h2>
    <div class="panel">
      <div class="detail">
        <div class="badge">read-only</div>
        <div class="muted">This viewer does not write DB, does not modify memory records, does not change eligibility flags, and does not trigger autoRecall.</div>
        <div class="muted">No apply, quarantine, archive, delete, reinforce, or write-db actions are exposed here.</div>
      </div>
    </div>
  </section>
</section>
