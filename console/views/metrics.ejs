<section class="toolbar">
  <h1>Metrics</h1>
  <button class="icon-button" data-refresh title="Refresh">↻</button>
</section>
<section class="grid metrics" data-metric-cards></section>
<section class="grid metrics" data-diversity-cards></section>
<section class="grid metrics" data-reinforcement-cards></section>
<section>
  <h2>Retrieval Diversity</h2>
  <div class="panel diversity-summary" data-retrieval-diversity></div>
</section>
<section>
  <h2>Reinforcement Concentration</h2>
  <div class="panel diversity-summary" data-reinforcement-concentration></div>
</section>
<section>
  <h2>Top Memories</h2>
  <div id="top-memories" class="panel table-wrap"></div>
</section>
<section>
  <h2>Recall Miss After Response</h2>
  <div class="panel diversity-summary" data-recall-miss-after-response></div>
</section>
<section>
  <h2>AutoRecall Injection Rate</h2>
  <div class="panel diversity-summary" data-auto-recall-injection-rate></div>
</section>
<section class="split">
  <section><h2>Retrieval Categories</h2><div class="panel" data-category-bars></div></section>
